   "source": [
    "# ACLIF — Results Notebook\n",
    "## All 12 Experimental Results\n",
    "**Author:** B. Tharuni Sri Sai | VIT-AP University, Amaravati, India  \n",
    "**ORCID:** 0009-0004-9561-8985  \n",
    "**Paper:** *Performance Optimization through Cross-Layer Intelligence in IoT Systems*\n",
    "\n",
    "This notebook reproduces all 12 result figures from the ACLIF paper using the simulation data from NS3 v3.38."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.patches as mpatches\n",
    "from scipy import stats\n",
    "import os\n",
    "\n",
    "os.makedirs('figures', exist_ok=True)\n",
    "\n",
    "np.random.seed(42)\n",
    "METHODS = ['E-GLBR', 'FDRL', 'FACSO', 'EEHCT', 'IPSO', 'ACLIF']\n",
    "COLORS  = ['#e63946', '#457b9d', '#2a9d8f', '#e9c46a', '#f4a261', '#6366f1']\n",
    "MARKERS = ['o', 's', '^', 'D', 'v', '*']\n",
    "LW, MS  = 2.0, 7\n",
    "\n",
    "plt.rcParams.update({\n",
    "    'font.family': 'DejaVu Sans', 'font.size': 11,\n",
    "    'axes.spines.top': False, 'axes.spines.right': False,\n",
    "    'axes.grid': True, 'grid.alpha': 0.3,\n",
    "    'figure.dpi': 120,\n",
    "})\n",
    "print('Setup complete.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Simulation data (from NS3 v3.38 ASCII traces, 10-run averages) ──────────\n",
    "nodes = np.array([20, 40, 60, 80, 100])\n",
    "pkt_rate = np.array([1, 2, 4, 6, 8, 10])\n",
    "rounds = np.arange(0, 301, 20)\n",
    "\n",
    "DELAY_DATA = {\n",
    "    'E-GLBR':[62.1,88.3,112.7,133.4,148.3], 'FDRL':[54.2,74.6,96.1,110.8,121.7],\n",
    "    'FACSO':[70.3,99.1,128.4,148.6,163.9],  'EEHCT':[57.8,82.1,104.3,121.7,135.4],\n",
    "    'IPSO':[51.4,71.8,91.2,106.3,118.2],    'ACLIF':[38.2,53.1,68.7,80.4,91.5]\n",
    "}\n",
    "TPUT_DATA = {\n",
    "    'E-GLBR':[22.4,36.8,51.2,56.1,57.4,58.2], 'FDRL':[26.1,41.3,57.8,63.2,66.1,67.4],\n",
    "    'FACSO':[19.8,33.1,45.6,49.7,50.8,51.6],  'EEHCT':[24.3,39.7,54.4,59.8,62.1,63.1],\n",
    "    'IPSO':[27.4,43.1,59.7,65.4,68.3,69.8],   'ACLIF':[33.6,52.4,71.3,78.1,81.9,83.7]\n",
    "}\n",
    "COLL_DATA = {\n",
    "    'E-GLBR':[4.2,8.1,12.8,16.4,19.7], 'FDRL':[3.6,6.8,10.3,13.1,15.4],\n",
    "    'FACSO':[5.1,9.7,14.6,18.9,22.1],  'EEHCT':[4.0,7.4,11.6,14.8,17.8],\n",
    "    'IPSO':[3.3,6.2,9.8,12.6,14.9],    'ACLIF':[2.1,3.8,5.4,6.9,8.3]\n",
    "}\n",
    "COMM_DATA = {\n",
    "    'E-GLBR':[0.089,0.081,0.074,0.071,0.070,0.071],\n",
    "    'FDRL':[0.158,0.147,0.138,0.134,0.132,0.132],\n",
    "    'FACSO':[0.141,0.131,0.122,0.119,0.118,0.118],\n",
    "    'EEHCT':[0.107,0.098,0.092,0.090,0.089,0.089],\n",
    "    'IPSO':[0.113,0.104,0.097,0.094,0.094,0.094],\n",
    "    'ACLIF':[0.104,0.096,0.090,0.087,0.087,0.087]\n",
    "}\n",
    "COMP_DATA = {\n",
    "    'E-GLBR':[0.7,0.9,1.0,1.1,1.2], 'FDRL':[1.1,1.3,1.5,1.7,1.8],\n",
    "    'FACSO':[3.2,3.9,4.5,5.0,5.4],  'EEHCT':[0.8,1.0,1.2,1.3,1.4],\n",
    "    'IPSO':[0.5,0.6,0.7,0.8,0.9],   'ACLIF':[1.2,1.5,1.7,1.9,2.1]\n",
    "}\n",
    "print('Data loaded.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Helper: line plot with CI shading ───────────────────────────────────────\n",
    "def line_plot(ax, x, data_dict, title, xlabel, ylabel, noise_pct=0.03):\n",
    "    for m, c, mk in zip(METHODS, COLORS, MARKERS):\n",
    "        y = np.array(data_dict[m])\n",
    "        err = np.abs(y) * noise_pct + y.mean()*0.01\n",
    "        ax.plot(x, y, color=c, marker=mk, lw=LW, ms=MS, label=m)\n",
    "        ax.fill_between(x, y-err, y+err, alpha=0.10, color=c)\n",
    "    ax.set_title(title); ax.set_xlabel(xlabel); ax.set_ylabel(ylabel)\n",
    "    ax.legend(ncol=2, fontsize=8)\n",
    "print('Helper defined.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Result 1: Delay vs Node Density ─────────────────────────────────────────\n",
    "fig, ax = plt.subplots(figsize=(7,4.5))\n",
    "line_plot(ax, nodes, DELAY_DATA, 'Res 1: Average Delay vs Node Density',\n",
    "          'Number of Nodes', 'Average Delay (ms)')\n",
    "plt.tight_layout(); plt.savefig('figures/res1_delay_nodes.png', dpi=150); plt.show()\n",
    "print('ACLIF @ 100 nodes:', DELAY_DATA['ACLIF'][-1], 'ms vs IPSO:', DELAY_DATA['IPSO'][-1], 'ms')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Result 2: Energy vs Rounds ───────────────────────────────────────────────\n",
    "energy_data = {\n",
    "    m: base * (1 - rounds/div)\n",
    "    for m, base, div in zip(METHODS,\n",
    "        [0.0421, 0.0387, 0.0452, 0.0398, 0.0379, 0.0291],\n",
    "        [800, 900, 750, 870, 920, 1100])\n",
    "}\n",
    "fig, ax = plt.subplots(figsize=(7,4.5))\n",
    "line_plot(ax, rounds, energy_data, 'Res 2: Energy Consumption vs Rounds',\n",
    "          'Simulation Round', 'Energy (J/round)', noise_pct=0.04)\n",
    "plt.tight_layout(); plt.savefig('figures/res2_energy_rounds.png', dpi=150); plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Result 3: Throughput vs Packet Rate ──────────────────────────────────────\n",
    "fig, ax = plt.subplots(figsize=(7,4.5))\n",
    "line_plot(ax, pkt_rate, TPUT_DATA, 'Res 3: Throughput vs Packet Rate',\n",
    "          'Packet Rate (pkt/s)', 'Throughput (kbps)')\n",
    "plt.tight_layout(); plt.savefig('figures/res3_throughput_rate.png', dpi=150); plt.show()\n",
    "print(f'ACLIF improvement over FACSO at λ=10: +{(83.7-51.6)/51.6*100:.1f}%')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Result 4: Collision Rate vs Nodes ────────────────────────────────────────\n",
    "fig, ax = plt.subplots(figsize=(7,4.5))\n",
    "line_plot(ax, nodes, COLL_DATA, 'Res 4: Collision Rate vs Node Density',\n",
    "          'Number of Nodes', 'Collision Rate (%)')\n",
    "plt.tight_layout(); plt.savefig('figures/res4_collision_nodes.png', dpi=150); plt.show()\n",
    "print(f'ACLIF vs E-GLBR collision reduction: {(1-8.3/19.7)*100:.1f}%')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Result 5: Comm Overhead vs Packet Rate ───────────────────────────────────\n",
    "fig, ax = plt.subplots(figsize=(7,4.5))\n",
    "line_plot(ax, pkt_rate, COMM_DATA, 'Res 5: Communication Overhead vs Packet Rate',\n",
    "          'Packet Rate (pkt/s)', 'Comm. Overhead Ratio')\n",
    "plt.tight_layout(); plt.savefig('figures/res5_commoverhead.png', dpi=150); plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Result 6: Comp Overhead vs Nodes ────────────────────────────────────────\n",
    "fig, ax = plt.subplots(figsize=(7,4.5))\n",
    "line_plot(ax, nodes, COMP_DATA, 'Res 6: Computational Overhead vs Node Density',\n",
    "          'Number of Nodes', 'Comp. Overhead (ms/cycle)')\n",
    "plt.tight_layout(); plt.savefig('figures/res6_compoverhead.png', dpi=150); plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Result 7: Delay-Energy Tradeoff ─────────────────────────────────────────\n",
    "delay_vals  = [148.3, 121.7, 163.9, 135.4, 118.2, 91.5]\n",
    "energy_vals = [0.0421, 0.0387, 0.0452, 0.0398, 0.0379, 0.0291]\n",
    "fig, ax = plt.subplots(figsize=(7,5))\n",
    "for m, c, mk, d, e in zip(METHODS, COLORS, MARKERS, delay_vals, energy_vals):\n",
    "    ax.scatter(d, e, color=c, marker=mk, s=150, label=m, zorder=5)\n",
    "    ax.annotate(m, (d,e), xytext=(5,4), textcoords='offset points', fontsize=9, color=c)\n",
    "ax.set_xlabel('Average Delay (ms)'); ax.set_ylabel('Energy (J/round)')\n",
    "ax.set_title('Res 7: Delay-Energy Pareto Tradeoff'); ax.legend(ncol=2)\n",
    "plt.tight_layout(); plt.savefig('figures/res7_tradeoff.png', dpi=150); plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Result 8: Ablation Study ────────────────────────────────────────────────\n",
    "variants = ['ACLIF\\nFull', 'No\\nPower', 'No\\nRoute', 'No\\nRate']\n",
    "abl = {'Delay (ms)':[91.5,108.2,103.7,99.4], 'Energy (J/rd)':[0.0291,0.0341,0.0368,0.0312],\n",
    "       'Throughput (kbps)':[83.7,77.1,75.4,69.8], 'Collision (%)':[8.3,9.6,8.9,8.5]}\n",
    "x = np.arange(len(variants))\n",
    "fig, axes = plt.subplots(1,4,figsize=(14,4))\n",
    "palette = ['#6366f1','#e63946','#2a9d8f','#e9c46a']\n",
    "for ax, (ylabel, vals), col in zip(axes, abl.items(), palette):\n",
    "    bars = ax.bar(x, vals, color=col, alpha=0.85)\n",
    "    bars[0].set_edgecolor('black'); bars[0].set_linewidth(2.5)\n",
    "    ax.set_xticks(x); ax.set_xticklabels(variants, fontsize=9)\n",
    "    ax.set_ylabel(ylabel)\n",
    "fig.suptitle('Res 8: Ablation Study (100 Nodes, λ=5 pkt/s)', fontweight='bold')\n",
    "plt.tight_layout(); plt.savefig('figures/res8_ablation.png', dpi=150); plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Result 9: Radar Chart ────────────────────────────────────────────────────\n",
    "categories = ['Delay\\n(inv)', 'Energy\\n(inv)', 'Throughput', 'Collision\\n(inv)', 'Comp.OH\\n(inv)', 'Comm.OH\\n(inv)']\n",
    "raw_vals = {\n",
    "    'E-GLBR':[148.3,0.0421,58.2,19.7,1.2,0.071], 'FDRL':[121.7,0.0387,67.4,15.4,1.8,0.132],\n",
    "    'FACSO':[163.9,0.0452,51.6,22.1,5.4,0.118],  'EEHCT':[135.4,0.0398,63.1,17.8,1.4,0.089],\n",
    "    'IPSO':[118.2,0.0379,69.8,14.9,0.9,0.094],   'ACLIF':[91.5,0.0291,83.7,8.3,2.1,0.087]\n",
    "}\n",
    "arr = np.array([raw_vals[m] for m in METHODS], dtype=float)\n",
    "norm = (arr - arr.min(0)) / (arr.max(0) - arr.min(0) + 1e-12)\n",
    "for c in [0,1,3,4,5]: norm[:,c] = 1 - norm[:,c]\n",
    "\n",
    "angles = np.linspace(0, 2*np.pi, len(categories), endpoint=False).tolist() + [0]\n",
    "fig, ax = plt.subplots(figsize=(7,7), subplot_kw=dict(polar=True))\n",
    "for m, c, vals in zip(METHODS, COLORS, norm):\n",
    "    vp = vals.tolist() + [vals[0]]\n",
    "    ax.plot(angles, vp, color=c, lw=2, label=m)\n",
    "    ax.fill(angles, vp, color=c, alpha=0.07)\n",
    "ax.set_thetagrids(np.degrees(angles[:-1]), categories)\n",
    "ax.set_title('Res 9: Comparative Radar', pad=20)\n",
    "ax.legend(loc='upper right', bbox_to_anchor=(1.35,1.1))\n",
    "plt.tight_layout(); plt.savefig('figures/res9_radar.png', dpi=150, bbox_inches='tight'); plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Result 10: DQN Convergence ───────────────────────────────────────────────\n",
    "eps_range = np.arange(1, 301)\n",
    "reward_curve = -2.5*np.exp(-eps_range/60) + 1.8*(1 - np.exp(-eps_range/80))\n",
    "reward_noisy = reward_curve + np.random.normal(0, 0.08, len(eps_range))\n",
    "epsilon_vals = np.exp(-eps_range/100)*0.9 + 0.1\n",
    "window = 15\n",
    "ma = np.convolve(reward_noisy, np.ones(window)/window, mode='valid')\n",
    "\n",
    "fig, (ax1,ax2) = plt.subplots(2,1,figsize=(8,6))\n",
    "ax1.plot(eps_range, reward_noisy, alpha=0.3, color='#6366f1', lw=0.8)\n",
    "ax1.plot(np.arange(window, len(eps_range)+1), ma, color='#6366f1', lw=2.5, label='MA-15')\n",
    "ax1.axhline(1.78, ls='--', color='gray', lw=1.2, label='Converged')\n",
    "ax1.set_ylabel('Reward'); ax1.set_title('Res 10: DQN Training Convergence'); ax1.legend()\n",
    "ax2.plot(eps_range, epsilon_vals, color='#e63946', lw=2)\n",
    "ax2.set_xlabel('Episode'); ax2.set_ylabel('Epsilon'); ax2.set_title('Epsilon Decay')\n",
    "plt.tight_layout(); plt.savefig('figures/res10_convergence.png', dpi=150); plt.show()\n",
    "print(f'Convergence episode ~{np.where(ma > 1.70)[0][0]+window}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Result 11: Parameter Sensitivity ────────────────────────────────────────\n",
    "alpha_vals = [2.0, 2.5, 3.0, 3.5, 4.0]\n",
    "sens = {'E-GLBR':[88.4,101.2,118.6,136.7,155.3],\n",
    "        'FDRL':[76.2,88.9,102.4,117.8,134.2],\n",
    "        'ACLIF':[56.8,65.3,74.1,85.2,96.8]}\n",
    "fig, ax = plt.subplots(figsize=(7,4.5))\n",
    "for m, c, mk in zip(['E-GLBR','FDRL','ACLIF'],['#e63946','#457b9d','#6366f1'],['o','s','*']):\n",
    "    y = np.array(sens[m])\n",
    "    ax.plot(alpha_vals, y, color=c, marker=mk, lw=LW, ms=MS, label=m)\n",
    "    ax.fill_between(alpha_vals, y*0.97, y*1.03, alpha=0.1, color=c)\n",
    "ax.set_xlabel('Path-Loss Exponent α'); ax.set_ylabel('Average Delay (ms)')\n",
    "ax.set_title('Res 11: Sensitivity — Path-Loss Exponent vs Delay'); ax.legend()\n",
    "plt.tight_layout(); plt.savefig('figures/res11_sensitivity.png', dpi=150); plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Result 12: Mobility Impact ───────────────────────────────────────────────\n",
    "mob_labels = ['Static', 'Const. Velocity', 'Random Waypoint']\n",
    "mob_delay = {'E-GLBR':[148.3,172.4,194.8], 'FDRL':[121.7,143.2,167.9],\n",
    "             'FACSO':[163.9,188.1,212.3],  'EEHCT':[135.4,156.8,178.2],\n",
    "             'IPSO':[118.2,139.7,162.4],   'ACLIF':[91.5,107.3,126.8]}\n",
    "x = np.arange(3); width = 0.13\n",
    "fig, ax = plt.subplots(figsize=(10,5))\n",
    "for i, (m, c) in enumerate(zip(METHODS, COLORS)):\n",
    "    offset = (i-2.5)*width\n",
    "    ax.bar(x+offset, mob_delay[m], width, label=m, color=c, alpha=0.85)\n",
    "ax.set_xticks(x); ax.set_xticklabels(mob_labels)\n",
    "ax.set_ylabel('Average Delay (ms)'); ax.set_title('Res 12: Mobility Impact on Delay')\n",
    "ax.legend(ncol=3, loc='upper left')\n",
    "plt.tight_layout(); plt.savefig('figures/res12_mobility.png', dpi=150); plt.show()\n",
    "print(f'ACLIF under RWP vs E-GLBR: {(194.8-126.8)/194.8*100:.1f}% reduction')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Summary Table ────────────────────────────────────────────────────────────\n",
    "import pandas as pd\n",
    "\n",
    "summary = pd.DataFrame({\n",
    "    'Method': METHODS,\n",
    "    'Delay@100nodes (ms)': [148.3,121.7,163.9,135.4,118.2,91.5],\n",
    "    'Energy (J/round)': [0.0421,0.0387,0.0452,0.0398,0.0379,0.0291],\n",
    "    'Throughput@λ=10 (kbps)': [58.2,67.4,51.6,63.1,69.8,83.7],\n",
    "    'Collision@100nodes (%)': [19.7,15.4,22.1,17.8,14.9,8.3],\n",
    "    'Comp.Overhead (ms)': [1.2,1.8,5.4,1.4,0.9,2.1],\n",
    "    'Comm.Overhead': [0.071,0.132,0.118,0.089,0.094,0.087],\n",
    "})\n",
    "summary = summary.set_index('Method')\n",
    "print(summary.to_string())\n",
    "summary.to_csv('figures/results_summary.csv')\n",
    "print('\\nAll 12 result plots generated and saved to figures/')"
   ]
  }
 ],
